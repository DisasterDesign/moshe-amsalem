# ── Client-side (must be set at BUILD time in Cloudflare Pages) ─────────────
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# ── Server-side, Cloudflare Pages Functions (runtime env vars) ──────────────
# Contact form
TURNSTILE_SECRET_KEY=
RESEND_API_KEY=

# Google reviews  (/api/reviews)
# API key from Google Cloud with "Places API (New)" enabled.
GOOGLE_PLACES_API_KEY=
# Optional. Exact place id. If empty, the function resolves the place once
# per day via Text Search using GOOGLE_PLACE_QUERY.
GOOGLE_PLACE_ID=
# Optional. Defaults to: משה אמסלם - משרד עורכי דין, דרך מנחם בגין 144, תל אביב
GOOGLE_PLACE_QUERY=
